{
  "name": "movie-ticket-reservation",
  "version": "1.0.0",
  "description": "Movie Ticket Reservation System — React + Redux + Node.js/Express + MongoDB",
  "main": "server/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "cross-env NODE_ENV=production node server/server.js",
    "dev": "nodemon server/server.js",
    "seed": "node server/seed/seedData.js",
    "build": "npm install --prefix client && npm run build --prefix client",
    "client": "npm run dev --prefix client",
    "dev:all": "concurrently \"npm run dev\" \"npm run client\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.9.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.14.1",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "nodemon": "^3.1.14"
  }
}
